{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menti.local/esme-posttrain/single-turn-instruction-manifest.schema.json",
  "title": "Single-turn instruction dataset manifest",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_type",
    "name",
    "required_fields",
    "sample_budget",
    "token_budget",
    "data_files"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "manifest_type": { "const": "single_turn_instruction" },
    "name": { "type": "string", "minLength": 1 },
    "required_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "instruction" } },
        { "contains": { "const": "response" } }
      ]
    },
    "sample_budget": { "type": "integer", "minimum": 1 },
    "token_budget": { "type": "integer", "minimum": 1 },
    "data_files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/jsonl_file" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "jsonl_file": {
      "type": "object",
      "required": ["path", "format", "records"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "format": { "const": "jsonl" },
        "records": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
