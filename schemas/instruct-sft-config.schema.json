{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Esme Instruct SFT Pilot Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_card",
    "requires_approval",
    "artifact_name",
    "starts_from",
    "base_bundle",
    "datasets",
    "budgets",
    "optimizer",
    "loss",
    "tuning",
    "sequence",
    "runtime",
    "monitoring",
    "artifacts",
    "learning_gate",
    "acceptance",
    "abort_rules"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "const": "esme_214m_instruct_sft_pilot" },
    "run_card": { "const": "run_cards/esme-214m-instruct.md" },
    "requires_approval": { "const": true },
    "artifact_name": { "const": "Esme-214M-Instruct" },
    "starts_from": { "const": "Esme-214M-Base" },
    "base_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format", "model_family", "read_only"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "format": { "const": "llm_pretrain_dense_v1" },
        "model_family": { "const": "DenseBackbone" },
        "read_only": { "const": true }
      }
    },
    "datasets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["non_commercial_training_approved", "train_mix", "eval_holdout"],
      "properties": {
        "non_commercial_training_approved": { "const": false },
        "train_mix": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "required": ["name", "source", "revision", "license", "split", "role", "mix_ratio"],
            "properties": {
              "name": { "enum": ["smol-smoltalk", "tulu-3-personas"] },
              "source": { "type": "string" },
              "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
              "license": { "enum": ["apache-2.0", "odc-by"] },
              "split": { "const": "train" },
              "role": { "const": "train" },
              "mix_ratio": { "enum": [0.8, 0.2] },
              "filters": { "type": "object" }
            }
          }
        },
        "eval_holdout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "source", "revision", "license", "split", "role", "usage", "train_allowed"],
          "properties": {
            "name": { "const": "no_robots" },
            "source": { "const": "HuggingFaceH4/no_robots" },
            "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
            "license": { "const": "cc-by-nc-4.0" },
            "split": { "const": "test" },
            "role": { "const": "eval" },
            "usage": { "const": "eval_only" },
            "train_allowed": { "const": false }
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "required": ["max_train_samples", "max_train_tokens", "target_train_tokens", "max_eval_samples", "max_eval_tokens", "matched_eval_samples_per_source", "matched_eval_tokens_per_source", "max_sequence_tokens", "smoke_train_samples", "smoke_train_tokens", "smoke_eval_samples"],
      "properties": {
        "max_train_samples": { "type": "integer", "minimum": 1, "maximum": 50000 },
        "max_train_tokens": { "type": "integer", "minimum": 1, "maximum": 50000000 },
        "target_train_tokens": { "type": "integer", "minimum": 1, "maximum": 50000000 },
        "max_eval_samples": { "type": "integer", "minimum": 1 },
        "max_eval_tokens": { "type": "integer", "minimum": 1 },
        "matched_eval_samples_per_source": { "type": "integer", "minimum": 1 },
        "matched_eval_tokens_per_source": { "type": "integer", "minimum": 1 },
        "max_sequence_tokens": { "type": "integer", "minimum": 2, "maximum": 1024 }
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "learning_rate", "micro_batch_size", "gradient_accumulation_steps", "effective_batch_size", "max_steps", "smoke_max_steps", "seed", "grad_clip", "scheduler", "warmup_steps", "weight_decay"],
      "properties": {
        "name": { "const": "AdamW" },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "micro_batch_size": { "type": "integer", "minimum": 1 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 1 },
        "effective_batch_size": { "type": "integer", "minimum": 1 },
        "max_steps": { "type": "integer", "minimum": 1 },
        "smoke_max_steps": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer", "minimum": 1 },
        "grad_clip": { "type": "number", "exclusiveMinimum": 0 },
        "scheduler": { "enum": ["constant", "linear_warmup_decay", "cosine_decay"] },
        "warmup_steps": { "type": "integer", "minimum": 0 },
        "weight_decay": { "type": "number", "minimum": 0 }
      }
    },
    "loss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assistant_only_loss", "completion_only_loss", "ignore_index"],
      "properties": {
        "assistant_only_loss": { "const": true },
        "completion_only_loss": { "const": true },
        "ignore_index": { "const": -100 }
      }
    },
    "tuning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": { "mode": { "const": "full" } }
    },
    "sequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence_packing", "pad_to_multiple_of", "no_packing_rationale"],
      "properties": {
        "sequence_packing": { "const": false },
        "pad_to_multiple_of": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "no_packing_rationale": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": { "type": "object" },
    "monitoring": {
      "type": "object",
      "required": [
        "log_interval",
        "eval_interval",
        "checkpoint_interval",
        "retain_last_checkpoints",
        "early_stopping_patience",
        "no_robots_catastrophic_regression_multiplier",
        "sample_new_tokens",
        "wandb_project",
        "wandb_required_for_modal"
      ]
    },
    "artifacts": { "type": "object" },
    "learning_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_run_requires_interval_eval_sweep", "evidence"],
      "properties": {
        "full_run_requires_interval_eval_sweep": { "const": true },
        "evidence": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "stopped_run_reconciliation"
              ],
              "properties": {
                "stopped_run_reconciliation": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["kind", "showcase_metrics_uri", "older_full_metrics_uri", "showcase_eval_rows", "showcase_best_step", "showcase_latest_step", "notes"],
                  "properties": {
                    "kind": { "const": "stopped_run_reconciliation" },
                    "showcase_metrics_uri": { "type": "string", "minLength": 1 },
                    "older_full_metrics_uri": { "type": "string", "minLength": 1 },
                    "showcase_eval_rows": { "const": 98 },
                    "showcase_best_step": { "const": 600 },
                    "showcase_latest_step": { "const": 19400 },
                    "notes": { "type": "string", "minLength": 1 }
                  }
                },
                "bounded_matched_interval_eval_sweep": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": [
                    "kind",
                    "eval_metric",
                    "baseline_step",
                    "step0_response_loss",
                    "best_response_loss",
                    "interval_eval_steps",
                    "evidence_uri"
                  ],
                  "properties": {
                    "kind": { "const": "bounded_matched_interval_eval_sweep" },
                    "eval_metric": { "const": "eval/matched/response_loss" },
                    "baseline_step": { "const": 0 },
                    "step0_response_loss": { "type": "number", "exclusiveMinimum": 0 },
                    "best_response_loss": { "type": "number", "exclusiveMinimum": 0 },
                    "interval_eval_steps": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "type": "integer", "minimum": 1 }
                    },
                    "evidence_uri": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          ]
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heldout_response_loss_required", "instruct_must_beat_base", "eval_dataset"],
      "properties": {
        "heldout_response_loss_required": { "const": true },
        "instruct_must_beat_base": { "const": true },
        "eval_dataset": { "const": "weighted matched SmolTalk/Tulu with no_robots OOD guardrail" }
      }
    },
    "abort_rules": { "type": "array", "items": { "type": "string" } }
  }
}
