{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menti.local/esme-posttrain/rl-task-manifest.schema.json",
  "title": "RL task dataset manifest with verifiable rewards",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_type",
    "name",
    "sample_budget",
    "token_budget",
    "reward_definitions",
    "data_files"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "manifest_type": { "const": "rl_tasks" },
    "name": { "type": "string", "minLength": 1 },
    "sample_budget": { "type": "integer", "minimum": 1 },
    "token_budget": { "type": "integer", "minimum": 1 },
    "reward_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "reward_type", "verifiable", "verifier", "pass_condition"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "reward_type": {
            "enum": ["exact_match", "numeric_match", "regex_match", "unit_test", "execution_check"]
          },
          "verifiable": { "const": true },
          "verifier": { "type": "string", "minLength": 1 },
          "pass_condition": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "data_files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/jsonl_file" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "jsonl_file": {
      "type": "object",
      "required": ["path", "format", "records"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "format": { "const": "jsonl" },
        "records": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
