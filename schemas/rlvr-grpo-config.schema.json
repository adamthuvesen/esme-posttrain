{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menti.local/esme-posttrain/rlvr-grpo-config.schema.json",
  "title": "Bounded RLVR GRPO launch config",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_card",
    "requires_approval",
    "artifact_name",
    "stage",
    "starts_from",
    "input_bundle",
    "dataset",
    "approval_gate",
    "budgets",
    "grpo",
    "reward_policy",
    "runtime",
    "monitoring",
    "pipeline_smoke",
    "artifacts",
    "acceptance",
    "abort_rules"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "const": "esme_214m_rlvr_countdown_lite_grpo" },
    "run_card": { "const": "run_cards/esme-214m-rl.md" },
    "requires_approval": { "const": true },
    "artifact_name": { "const": "Esme-214M-RL" },
    "stage": { "const": "rlvr" },
    "starts_from": { "const": "Esme-214M-Chat" },
    "input_bundle": { "$ref": "#/$defs/input_bundle" },
    "dataset": { "$ref": "#/$defs/dataset" },
    "approval_gate": { "$ref": "#/$defs/approval_gate" },
    "budgets": { "$ref": "#/$defs/budgets" },
    "grpo": { "$ref": "#/$defs/grpo" },
    "reward_policy": { "$ref": "#/$defs/reward_policy" },
    "runtime": { "type": "object" },
    "monitoring": { "$ref": "#/$defs/monitoring" },
    "pipeline_smoke": { "$ref": "#/$defs/pipeline_smoke" },
    "artifacts": { "$ref": "#/$defs/artifacts" },
    "acceptance": { "$ref": "#/$defs/acceptance" },
    "abort_rules": {
      "type": "array",
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "input_bundle": {
      "type": "object",
      "required": ["path", "format", "model_family", "read_only"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "format": { "const": "llm_pretrain_dense_v1" },
        "model_family": { "const": "DenseBackbone" },
        "read_only": { "const": true }
      },
      "additionalProperties": false
    },
    "dataset": {
      "type": "object",
      "required": [
        "name",
        "manifest_path",
        "train_split",
        "eval_split",
        "secondary_transfer_eval",
        "remote_download_allowed",
        "train_on_gsm8k_lite"
      ],
      "properties": {
        "name": { "const": "esme_214m_rl_countdown_lite" },
        "manifest_path": { "type": "string", "minLength": 1 },
        "train_split": { "const": "train" },
        "eval_split": { "const": "eval" },
        "secondary_transfer_eval": { "const": "GSM8K-lite" },
        "remote_download_allowed": { "const": false },
        "train_on_gsm8k_lite": { "const": false }
      },
      "additionalProperties": false
    },
    "approval_gate": {
      "type": "object",
      "required": ["requires_adam_approval", "approved", "blocked_actions"],
      "properties": {
        "requires_adam_approval": { "const": true },
        "approved": { "const": true },
        "blocked_actions": {
          "type": "array",
          "contains": { "const": "modal" }
        }
      },
      "additionalProperties": false
    },
    "budgets": {
      "type": "object",
      "required": [
        "dataset_sample_budget",
        "train_task_budget",
        "eval_task_budget",
        "max_rollout_tokens",
        "max_eval_rollouts"
      ],
      "properties": {
        "dataset_sample_budget": { "type": "integer", "minimum": 1 },
        "train_task_budget": { "type": "integer", "minimum": 1 },
        "eval_task_budget": { "type": "integer", "minimum": 1 },
        "max_rollout_tokens": { "type": "integer", "minimum": 1 },
        "max_eval_rollouts": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "grpo": {
      "type": "object",
      "required": [
        "method",
        "max_steps",
        "prompts_per_step",
        "group_size",
        "max_new_tokens",
        "temperature",
        "clip_epsilon",
        "kl_beta",
        "learning_rate",
        "weight_decay",
        "warmup_steps",
        "scheduler",
        "grad_clip",
        "seed"
      ],
      "properties": {
        "method": { "const": "grpo" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "prompts_per_step": { "type": "integer", "minimum": 1 },
        "group_size": { "type": "integer", "minimum": 2 },
        "max_new_tokens": { "type": "integer", "minimum": 1 },
        "temperature": { "type": "number", "exclusiveMinimum": 0 },
        "clip_epsilon": { "type": "number", "exclusiveMinimum": 0 },
        "kl_beta": { "type": "number", "minimum": 0 },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "weight_decay": { "type": "number", "minimum": 0 },
        "warmup_steps": { "type": "integer", "minimum": 0 },
        "scheduler": { "enum": ["constant", "linear_warmup_decay", "cosine_decay"] },
        "grad_clip": { "type": "number", "exclusiveMinimum": 0 },
        "seed": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "reward_policy": {
      "type": "object",
      "required": [
        "verifiable_only",
        "exact_solve_reward",
        "valid_expression_reward",
        "invalid_reward",
        "disallowed_observation_terms"
      ],
      "properties": {
        "verifiable_only": { "const": true },
        "exact_solve_reward": { "type": "number" },
        "valid_expression_reward": { "type": "number" },
        "invalid_reward": { "type": "number" },
        "disallowed_observation_terms": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "monitoring": {
      "type": "object",
      "required": [
        "log_interval",
        "checkpoint_interval",
        "samples_per_eval_task",
        "eval_max_new_tokens",
        "eval_progress_interval_tasks",
        "eval_progress_interval_samples",
        "eval_sample_batch_size",
        "eval_wall_timeout_seconds",
        "eval_wall_timeout_seconds_per_sample",
        "eval_no_progress_timeout_seconds",
        "eval_no_progress_timeout_seconds_per_sample",
        "debug_eval_task_budget",
        "debug_samples_per_eval_task",
        "wandb_project",
        "wandb_required_for_modal",
        "wandb_tags"
      ],
      "properties": {
        "log_interval": { "type": "integer", "minimum": 1 },
        "checkpoint_interval": { "type": "integer", "minimum": 1 },
        "samples_per_eval_task": { "type": "integer", "minimum": 1 },
        "eval_max_new_tokens": { "type": "integer", "minimum": 1 },
        "eval_progress_interval_tasks": { "type": "integer", "minimum": 1 },
        "eval_progress_interval_samples": { "type": "integer", "minimum": 1 },
        "eval_sample_batch_size": { "type": "integer", "minimum": 1 },
        "eval_wall_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "eval_wall_timeout_seconds_per_sample": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "eval_no_progress_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "eval_no_progress_timeout_seconds_per_sample": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "debug_eval_task_budget": { "type": "integer", "minimum": 1 },
        "debug_samples_per_eval_task": { "type": "integer", "minimum": 1 },
        "wandb_project": { "type": "string", "minLength": 1 },
        "wandb_required_for_modal": { "const": true },
        "wandb_tags": {
          "type": "array",
          "contains": { "const": "stage=rlvr" },
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "pipeline_smoke": {
      "type": "object",
      "required": [
        "profile",
        "enabled",
        "train_task_budget",
        "max_steps",
        "warmup_steps",
        "prompts_per_step",
        "group_size",
        "max_new_tokens",
        "max_rollout_tokens",
        "eval_task_budget",
        "samples_per_eval_task",
        "eval_max_new_tokens",
        "eval_progress_interval_tasks",
        "eval_progress_interval_samples",
        "eval_sample_batch_size",
        "eval_wall_timeout_seconds",
        "eval_no_progress_timeout_seconds",
        "output_dir",
        "report_path",
        "doc_path"
      ],
      "properties": {
        "profile": { "const": "pipeline_smoke" },
        "enabled": { "const": true },
        "train_task_budget": { "type": "integer", "minimum": 1 },
        "max_steps": { "type": "integer", "minimum": 1 },
        "warmup_steps": { "type": "integer", "minimum": 0 },
        "prompts_per_step": { "type": "integer", "minimum": 1 },
        "group_size": { "type": "integer", "minimum": 2 },
        "max_new_tokens": { "type": "integer", "minimum": 1 },
        "max_rollout_tokens": { "type": "integer", "minimum": 1 },
        "eval_task_budget": { "type": "integer", "minimum": 1 },
        "samples_per_eval_task": { "type": "integer", "minimum": 1 },
        "eval_max_new_tokens": { "type": "integer", "minimum": 1 },
        "eval_progress_interval_tasks": { "type": "integer", "minimum": 1 },
        "eval_progress_interval_samples": { "type": "integer", "minimum": 1 },
        "eval_sample_batch_size": { "type": "integer", "minimum": 1 },
        "eval_wall_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "eval_no_progress_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "output_dir": { "type": "string", "pattern": "^runs/" },
        "report_path": { "type": "string", "pattern": "^artifacts/" },
        "doc_path": { "type": "string", "pattern": "^docs/" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["output_dir", "report_path", "doc_path", "required_files"],
      "properties": {
        "output_dir": { "type": "string", "pattern": "^runs/" },
        "report_path": { "type": "string", "pattern": "^artifacts/" },
        "doc_path": { "type": "string", "pattern": "^docs/" },
        "required_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "object",
      "required": [
        "primary_metric",
        "baseline_valid_expression_rate",
        "baseline_exact_solve_rate",
        "baseline_pass_at_1",
        "baseline_pass_at_8",
        "baseline_pass_at_32",
        "record_no_improvement"
      ],
      "properties": {
        "primary_metric": { "const": "valid_expression_rate" },
        "baseline_valid_expression_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "baseline_exact_solve_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "baseline_pass_at_1": { "type": "number", "minimum": 0, "maximum": 1 },
        "baseline_pass_at_8": { "type": "number", "minimum": 0, "maximum": 1 },
        "baseline_pass_at_32": { "type": "number", "minimum": 0, "maximum": 1 },
        "record_no_improvement": { "const": true }
      },
      "additionalProperties": false
    }
  }
}
