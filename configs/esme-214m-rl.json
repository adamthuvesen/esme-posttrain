{
  "schema_version": 1,
  "run_id": "esme_214m_rlvr_countdown_lite_grpo",
  "run_card": "run_cards/esme-214m-rl.md",
  "requires_approval": true,
  "artifact_name": "Esme-214M-RL",
  "stage": "rlvr",
