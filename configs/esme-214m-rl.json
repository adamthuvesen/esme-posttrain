        "projection_source": "bounded local estimate plus Modal GPU pricing checked 2026-06-30",
        "measured": false
      },
      "A100": {
        "modal_gpu": "A100",
        "usd_per_hour": 2.0988,
        "projected_tokens_per_second": 220.0,
        "rationale": "first bounded tranche uses A100 to keep synchronous before/after eval under a short wall-clock cap",
        "projection_source": "Modal pricing page lists A100 at $0.000583/sec; checked 2026-06-30",
        "measured": false
      }
    },
    "precision": "bf16",
    "smoke_max_cost_usd": 2.0,
